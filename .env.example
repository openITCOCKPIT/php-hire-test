# Copy this file to `.env` and adjust if needed:  cp .env.example .env
# `.env` itself is git-ignored so credentials never land in the repository.

# --- MySQL container bootstrap ---
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_DATABASE=recipes
MYSQL_USER=recipes
MYSQL_PASSWORD=recipes_secret

# --- Application (read by CakePHP) ---
# DATABASE_URL host is the compose service name "mysql", not localhost.
# CakePHP parses this DSN; it overrides the host/username defaults in app_local.php.
DATABASE_URL=mysql://recipes:recipes_secret@mysql/recipes
# Separate database for the PHPUnit suite (same engine as prod, not SQLite).
DATABASE_TEST_URL=mysql://recipes:recipes_secret@mysql/test_recipes
# Generate your own with:  openssl rand -hex 32
SECURITY_SALT=change-me-to-a-random-64-char-hex-string
# Origin allowed to call the API (the Angular dev server).
CORS_ALLOW_ORIGIN=http://localhost:4200

# Mail (issues #13 / Mailpit). The Docker stack includes Mailpit; sending over
# SMTP makes e-mails visible in its web UI at http://localhost:8025.
# Leave EMAIL_TRANSPORT_DEFAULT_URL empty to fall back to the Debug transport
# (logs to logs/debug.log, no mail server needed).
EMAIL_FROM=recipes@example.com
EMAIL_TRANSPORT_DEFAULT_URL=smtp://mailpit:1025
MAILPIT_WEB_PORT=8025

# --- Host port mapping ---
# Single-origin app (SPA + proxied API) — open this in a browser.
APP_PORT=8080
# Backend nginx, exposed for the dev workflow (ng serve → :8765/api).
NGINX_PORT=8765
# Host port for MySQL. Change it (e.g. 3307) if a local MySQL or MariaDB already
# occupies 3306. The container-internal port is always 3306.
MYSQL_PORT=3306
