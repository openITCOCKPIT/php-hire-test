# Copy this file to `.env` and adjust if needed:  cp .env.example .env
# `.env` itself is git-ignored so credentials never land in the repository.

# --- MySQL container bootstrap ---
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_DATABASE=recipes
MYSQL_USER=recipes
MYSQL_PASSWORD=recipes_secret

# --- Application database connection (read by PHP) ---
# DB_HOST is the compose service name, not localhost, inside the network.
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=recipes
DB_USERNAME=recipes
DB_PASSWORD=recipes_secret

# --- Host port mapping ---
# nginx is exposed on 8765 to match the Angular environment.apiBaseUrl used later.
NGINX_PORT=8765
# Host port for MySQL. Default 3306; change it (e.g. 3307) if a local MySQL or
# MariaDB already occupies 3306. The container-internal port is always 3306.
MYSQL_PORT=3307
